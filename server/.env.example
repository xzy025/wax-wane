# LLM API Configuration
# Supports any OpenAI-compatible API (DeepSeek, Qwen, Moonshot, OpenAI, etc.)

LLM_API_URL=https://api.deepseek.com/v1/chat/completions
LLM_API_KEY=sk-your-api-key-here
LLM_MODEL=deepseek-chat

# RAG / embeddings
# Model used by the embeddings endpoint (rag/embedding.ts). Falls back to a
# deterministic char-ngram embedder when no embeddings API is available.
EMBEDDING_MODEL=text-embedding-3-small

# Observability (rag/agent tracing — see observability/tracer.ts)
# Max traces kept in the in-memory ring buffer.
OBS_MAX_TRACES=100
# Optional: append completed traces as JSONL to this dir (off by default).
# OBS_TRACE_DIR=./.traces
